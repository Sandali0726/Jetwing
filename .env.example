# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase dashboard → Project Settings → API
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (NEVER expose to the browser). Bypasses Row Level Security.
# Used by API routes / workers for ETL, scoring, and email generation.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Claude (Edge Functions) ──────────────────────────────────────────────────
# Set as Supabase secrets (supabase secrets set ANTHROPIC_API_KEY=...), not here,
# since the offer/email generation runs inside Edge Functions.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8           # optional override (default: claude-opus-4-8)

# Optional shared secret guarding the Edge Functions. If set here AND as a
# Supabase secret, the Next.js routes forward it as x-function-secret.
# EDGE_FUNCTION_SECRET=

# ── External services (added in later phases) ────────────────────────────────
# HF_API_TOKEN=hf_...
# HF_SCORING_ENDPOINT=https://...
# HF_MODEL_VERSION=v1
# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=offers@jetwingsymphony.com
# SENDGRID_WEBHOOK_SECRET=
